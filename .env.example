# Copy this file to .env and fill in your values.
# The server will refuse to start if any required variable is missing.

# Required
NODE_ENV=development          # 'development' | 'production' | 'test'
PORT=3001
ADMIN_SECRET=change-me-before-deploy   # CLI/curl usage: x-admin-secret header
ADMIN_PASSWORD=change-me-before-deploy # Admin dashboard login password (min 8 chars)
JWT_SECRET=change-me-to-a-random-32-char-string-minimum # Signs JWT tokens (min 32 chars)

# Optional (defaults shown)
CORS_ORIGIN=http://localhost:3000      # In production set this to the exact frontend URL, e.g. https://your-frontend.vercel.app

# Required — Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
